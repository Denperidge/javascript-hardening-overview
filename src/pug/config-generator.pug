---
layout: layout.pug
permalink: /config-generator/index.html
---

mixin radio(name, value, projectFile=null, globalFile=null)
    input(type="radio" id=value name=name value=value data-project= projectFile data-global=globalFile)
    label(for=value)=value
- const dataSet = dataSets[0]
- const features = dataSet.features
- const tools = dataSet.tools;

link(rel="stylesheet", href="/static/config-generator.css")
form
    fieldset#general-settings
        legend General settings
        fieldset
            legend Scope
            +radio("scope", "project")
            +radio("scope", "global")
        
        fieldset
            legend Tools
            for tool in tools   
                unless tool.config_generator
                    +radio("tool", tool.id)
                else
                    - console.log(tool.config_generator.project)
                    +radio("tool", tool.id, tool.config_generator.project)
    hr

    section#inputs!=inputs

    hr

    section#output
        h2 Output
        span#filename
        textarea#out
        
    //for feature, featureIndex in features
        fieldset
            legend=feature.title
            for impl, toolId in feature.implementations
                if impl.config_generator
                    - const cfg = impl.config_generator
                    input(type=cfg.arg, name=`f${featureIndex}-${toolId}`)

    script(src="/static/config-generator.js")