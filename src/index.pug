doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Document
    body
        main
            for dataSet in dataSets
                - 
                    const features = dataSet.features;
                    const tools = dataSet.tools;
                    const toolIds = dataSet.toolIds;
                section
                    h2=dataSet.title
                    table
                        tr
                            th Feature
                            for packageManager in tools
                                unless packageManager.url
                                    th=`${packageManager.name} (${packageManager.version})`
                                else
                                    th
                                        a(href=packageManager.url)=`${packageManager.name} (${packageManager.version})`
                        for feature in features
                            tr
                                td=feature.title
                                for toolId in toolIds
                                    - const impl = feature.implementations[toolId]
                                    unless impl.url
                                        td!=impl.prettyPrint
                                    else
                                        td
                                            if impl.override
                                                - impl.prettyPrint += ", has override"
                                            a(href=impl.url)
                                                span=impl.prettyPrint
                                            if impl.override_url
                                                span , has #[a(href=impl.override_url) override]