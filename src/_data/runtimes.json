{
    "$schema": "./schema.json",
    "title": "Runtime overview",
    "tools": [
        {
            "id": "node",
            "name": "Node.JS",
            "version": "24.12.X"
        },
        {
            "id": "bun-runtime",
            "name": "Bun runtime",
            "version": "1.3.X"
        },
        {
            "id": "deno",
            "name": "Deno",
            "version": "2.6.X"
        }
    ],
    "features": [
        {
            "title": "Limit resource access",
            "implementations": {
                "node": {
                    "warning": "limited",
                    "note": "If configured, limited to some built-in node api's",
                    "url": "https://nodejs.org/api/permissions.html"
                },
                "deno": {
                    "url": "https://docs.deno.com/runtime/fundamentals/security/",
                    "override": true
                }
            }
        },
        {
            "title": "Freezing intrinsics/built-ins",
            "implementations": {
                "node": {
                    "warning": "configurable",
                    "url": "https://nodejs.org/en/learn/getting-started/security-best-practices"
                }
            }
        },
        {
            "title": "Runtime-level package auditor",
            "implementations": {
                "bun-runtime": {
                    "warning": "configurable",
                    "url": "https://bun.com/docs/runtime/bunfig#install-security-scanner"
                }
            }
        }
    ]
}