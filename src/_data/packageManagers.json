{
    "$schema": "./schema.json",
    "title": "packageManager",
    "tools": [
        {
            "id": "npm",
            "name": "npm",
            "version": "11.7.X"
        },
        {
            "id": "yarn-classic",
            "name": "Yarn Classic",
            "version": "1.22.X"
        },
        {
            "id": "yarn-berry",
            "name": "Yarn Berry",
            "version": "4.12.X"
        }, 
        {
            "id": "pnpm",
            "name": "pnpm",
            "version": "10.23.X"
        },
        {
            "id": "bun-install",
            "name": "Bun Install",
            "version": "1.3.X"
        }
    ],
    "features": [
        {
            "title": "Supports big 3 🐇 runtimes (Node.JS, deno, bun)",
            "implementations": {
                "npm": {
                    "warning": true,
                    "note": "Node.JS and Deno only"
                },
                "yarn-classic": {
                    "note": "Node.JS only",
                    "warning": true
                },
                "yarn-berry": {
                    "note": "Node.JS only",
                    "warning": true
                },
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/blog/releases/10.14#added-support-for-javascript-runtime-installation"
                },
                "bun-install": {
                    "warning": true,
                    "note": "Node.JS and Bun only"
                }
            }
        }
    ]
    
}