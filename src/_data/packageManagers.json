{
    "$schema": "./schema.json",
    "title": "Package Manager overview",
    "tools": [
        {
            "id": "npm",
            "name": "npm",
            "version": "11.7.X",
            "config_generator": {
                "project": ".npmrc",
                "global": "~/.npmrc",
                "url": "https://npm.github.io/installation-setup-docs/customizing/the-npmrc-file.html"
            }
        },
        {
            "id": "yarn-classic",
            "name": "Yarn Classic",
            "version": "1.22.X"
        },
        {
            "id": "yarn-berry",
            "name": "Yarn Berry",
            "version": "4.12.X"
        }, 
        {
            "id": "pnpm",
            "name": "pnpm",
            "version": "10.23.X",
            "config_generator": {
                "url": "https://pnpm.io/cli/config",
                "project": "pnpm-workspace.yaml",
                "global": "~/.config/pnpm/rc"
            }
        },
        {
            "id": "bun-install",
            "name": "Bun Install",
            "version": "1.3.X"
        }
    ],
    "features": [
        {
            "title": "Supports big 3 🐇 runtimes (Node.JS, deno, bun)",
            "implementations": {
                "npm": {
                    "warning": true,
                    "note": "Node.JS and Deno only"
                },
                "yarn-classic": {
                    "note": "Node.JS only",
                    "warning": true
                },
                "yarn-berry": {
                    "note": "Node.JS only",
                    "warning": true
                },
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/blog/releases/10.14#added-support-for-javascript-runtime-installation"
                },
                "bun-install": {
                    "warning": true,
                    "note": "Node.JS and Bun only"
                }
            }
        },
        {
            "title": "Minimum release age",
            "implementations": {
                "yarn-berry": {
                    "defaultValue": "3d",
                    "url": "https://yarnpkg.com/configuration/yarnrc#npmMinimalAgeGate",
                    "config_generator": {
                        "project": "npmMinimalAgeGate: '{0}'",
                        "arg": "text",
                        "note": "in days. Example value (3 days): 3d"
                    }
                },
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/settings#minimumreleaseage",
                    "override_url": "https://pnpm.io/settings#minimumreleaseageexclude",
                    "config_generator": {
                        "project": "minimumReleaseAge: {0}  # in minutes",
                        "global": "minimumReleaseAge={0}",
                        "arg": "number",
                        "note": "in minutes. Example value (3 days): 4320"
                    }
                },
                "bun-install": {
                    "config": true,
                    "url": "https://bun.com/docs/pm/cli/install#minimum-release-age"
                }
            }
        },
        {
            "title": "Block install scripts",
            "implementations": {
                "npm": {
                    "config": true,
                    "url": "https://docs.npmjs.com/cli/v11/using-npm/config#ignore-scripts"
                },
                "yarn-berry": {
                    "need_more_info": true,
                    "note": "[Documentation](https://yarnpkg.com/configuration/yarnrc#enableScripts) [unclear](https://github.com/yarnpkg/yarn/issues/7338)"
                },
                "pnpm": {
                    "note": "[Default](https://pnpm.io/settings#dangerouslyallowallbuilds), with [allowlist override](https://pnpm.io/settings#allowbuilds) and [strict mode (exit instead of warn)](https://pnpm.io/settings#strictdepbuilds)"
                },
                "bun-install": {
                    "warning": true,
                    "note": "Default, only blocks dependencies, has allowlist override",
                    "url": "https://bun.com/docs/pm/cli/install#lifecycle-scripts"
                }
            }
        },
        {
            "title": "Block git repo/tarball sources for indirect dependencies",
            "implementations": {
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/settings#blockexoticsubdeps"
                }
            }
        },
        {
            "title": "Don't install newer versions if security measures decreased",
            "implementations": {
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/settings#trustpolicy",
                    "override_url": "https://pnpm.io/settings#trustpolicyexclude"
                }
            }
        },
        {
            "title": "Limit plug & play to listed dependencies",
            "implementations": {
                "npm": {"note": "N/A"},
                "yarn-classic": {
                    "warning": true,
                    "note": "Default, with exception of top-level (package.json) dependencies"
                },
                "yarn-berry": {
                    "url": "https://yarnpkg.com/configuration/yarnrc#pnpMode"
                },
                "pnpm": {
                    "config": true,
                    "url": "https://pnpm.io/blog/2020/10/17/node-modules-configuration-options-with-pnpm#a-strict-traditional-modules-directory",
                    "override": true
                },
                "bun-install": {
                    "config": true,
                    "url": "https://bun.com/docs/pm/cli/install#default-strategy"
                }
            }
        },
        {
            "title": "Verify integrity of global store",
            "implementations": {
                "npm": {"need_more_info": true},
                "yarn-classic": {"need_more_info": true},
                "yarn-berry": {
                    "url": "https://yarnpkg.com/configuration/yarnrc#checksumBehavior",
                    "override": true
                },
                "pnpm": {
                    "url": "https://pnpm.io/settings#verifystoreintegrity",
                    "override": true
                },
                "bun-install": {"need_more_info": true}
            }
        },
        {
            "title": "Anti-lockfile poisoning",
            "implementations": {
                "yarn-berry": {
                    "config": true,
                    "note": "[Default for public PR](https://yarnpkg.com/configuration/yarnrc#enableHardenedMode), can be set to [true to do so everywhere](https://github.com/yarnpkg/berry/discussions/7026#discussioncomment-15375799)"
                },
                "pnpm": {
                    "note": "Not needed"
                },
                "bun-install": {
                    "note": "Not needed"
                }
            }
        }
    ]
    
}