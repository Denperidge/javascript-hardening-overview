{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "A collection of JS securty config measures",
    "type":"object",
    "$defs": {
        "featureImplementation": {
            "oneOf": [
                {"type": "object"},
                {"type": "null"}
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "warning": {
                    "type": "string",
                    "enum": [
                        "limited",
                        "configurable",
                        "need_more_info"
                    ], 
                    "default": "ok"
                },
                "override": {
                    "type": "boolean"
                },
                "override_url" : {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "config_generator": {
                    "type": "object",
                    "properties": {
                        "global": {
                            "oneOf": [
                                {"type": "string"},
                                {
                                    "type": "array",
                                    "items": {"type": "string"}
                                }
                            ]
                        },
                        "project": {
                            "oneOf": [
                                {"type": "string"},
                                {
                                    "type": "array",
                                    "items": {"type": "string"}
                                }
                            ]
                        },
                        "url": {
                            "type": "string"
                        },
                        "note": {
                            "type": "string"
                        },
                        "arg": {
                            "type": "string",
                            "enum": [
                                "text",
                                "number",
                                "checkbox",
                                "select"
                            ]
                        },
                        "options": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "defaultValue": {
                    "oneOf": [
                        {"type": "string"},
                        {"type": "number"},
                        {"type": "boolean"}
                    ]
                }
            }
        }
    },
    "properties": {
        "title": {
            "type": "string"
        },
        "tools": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "name", "version"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "version": {
                        "type": "string"
                    },
                    "url": {
                        "type": "string"
                    },
                    "config_generator": {
                        "type": "object",
                        "properties": {
                            "global": {
                                "type": "string"
                            },
                            "project": {
                                "type": "string"
                            },
                            "globalComment": {
                                "type": "string"
                            },
                            "projectComment": {
                                "type": "string"
                            },
                            "url": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "features": {
            "type":"array",
            "items": {
                "type": "object",
                "required": ["title", "implementations"],
                "properties": {
                    "title": {"type": "string"},
                    "implementations": {
                        "type": "object",
                        "properties": {
                            "npm": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "yarn-classic": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "yarn-berry": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "pnpm": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "bun-install": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "node": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "bun-runtime": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "deno": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "socket-npm": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "npq": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "npm-audit": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "yarn-audit": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "pnpm-audit": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "lockfile-lint": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "socket-scan": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "artemis": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "mend-renovate-cli": {
                                "$ref": "#/$defs/featureImplementation"
                            }
                        }
                    }
                }
            }
        }
    }
}