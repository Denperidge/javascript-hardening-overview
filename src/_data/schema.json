{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "A collection of JS securty config measures",
    "type":"object",
    "$defs": {
        "featureImplementation": {
            "oneOf": [
                {"type": "object"},
                {"type": "null"}
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "warning": {
                    "type": "boolean",
                    "default": false
                },
                "config": {
                    "type": "boolean"
                },
                "override_url": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "defaultValue": {
                    "oneOf": [
                        {"type": "string"},
                        {"type": "number"},
                        {"type": "boolean"}
                    ]
                }
            }
        }
    },
    "properties": {
        "title": {
            "type": "string"
        },
        "tools": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "name", "version"],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "version": {
                        "type": "string"
                    },
                    "url": {
                        "type": "string"
                    }
                }
            }
        },
        "features": {
            "type":"array",
            "items": {
                "type": "object",
                "required": ["title", "implementations"],
                "properties": {
                    "title": {"type": "string"},
                    "implementations": {
                        "type": "object",
                        "properties": {
                            "npm": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "yarn-classic": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "yarn-berry": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "pnpm": {
                                "$ref": "#/$defs/featureImplementation"
                            },
                            "bun-install": {
                                "$ref": "#/$defs/featureImplementation"
                            }
                        }
                    }
                }
            }
        }
    }
}